DATABASE_URL=postgresql://crm_user:crm_password@localhost:5432/crm
JWT_SECRET=change_this_secret_key_min_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_key
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Cloudflare Tunnel — add your tunnel domain here when running locally
# This is added to the CORS whitelist alongside CORS_ORIGIN
CLOUDFLARE_TUNNEL_DOMAIN=      # e.g. https://crm.yourdomain.com
CLOUDFLARE_TUNNEL_TOKEN=       # from: cloudflared tunnel token <name>
APP_PUBLIC_URL=                # same as CLOUDFLARE_TUNNEL_DOMAIN (used in email links)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=CRM <your_email@gmail.com>

# AI Provider — set ONE of these (priority: Groq → OpenRouter → Mistral)
GROQ_API_KEY=          # free at console.groq.com — recommended
OPENROUTER_API_KEY=    # free credits at openrouter.ai
MISTRAL_API_KEY=       # free tier at console.mistral.ai
AI_MODEL=              # optional override, e.g. llama-3.3-70b-versatile

# OpenAI Whisper (optional, for audio transcription only)
OPENAI_API_KEY=
WHISPER_ENABLED=false

# File storage — Cloudflare R2 (free: 10GB) or AWS S3
# For R2: get keys from dash.cloudflare.com → R2 → API Tokens
AWS_ACCESS_KEY_ID=        # R2 Access Key ID
AWS_SECRET_ACCESS_KEY=    # R2 Secret Access Key
AWS_S3_BUCKET=            # your bucket name
AWS_REGION=auto           # use "auto" for R2, or e.g. "ap-south-1" for AWS
AWS_ENDPOINT_URL=         # R2 only: https://<account-id>.r2.cloudflarestorage.com
AWS_PUBLIC_URL=           # R2 only: public bucket URL if enabled (optional)

# Cloudinary (free - persistent file storage, cloudinary.com)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

STORAGE_PATH=./uploads
MAX_FILE_SIZE=104857600

AGENT_INTERVAL=300000
DIGEST_HOUR=8
DIGEST_MINUTE=0
