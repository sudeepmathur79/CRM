VITE_API_URL=http://localhost:3000/api
VITE_GOOGLE_CLIENT_ID=             # Google OAuth client ID (optional)

# Cloudflare Turnstile site key — leave blank to disable CAPTCHA in dev
VITE_TURNSTILE_SITE_KEY=           # from dash.cloudflare.com > Turnstile > your site > Site key

# PostHog analytics — leave blank to disable
VITE_POSTHOG_KEY=                  # from posthog.com → Project → Settings → Project API Key
VITE_POSTHOG_HOST=                 # optional, defaults to https://app.posthog.com
